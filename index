<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doppler Obstétrico - Presentación Profesional (Diapositivas 1-12)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        /* CONFIGURACIÓN BASE */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background-color: #f1f5f9; display: grid; gap: 50px; grid-template-columns: 1fr; place-items: center; padding: 40px 0; }

        .slide-container {
            width: 1280px; height: 720px;
            background-color: #ffffff;
            font-family: 'Inter', sans-serif;
            position: relative;
            overflow: hidden;
            display: flex; flex-direction: column;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        /* DISEÑO DE FONDO COMÚN (Abstract shapes) */
        .slide-container::before {
            content: "";
            position: absolute; top: -100px; right: -100px;
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(0, 188, 212, 0.1) 0%, transparent 70%);
            z-index: 0;
        }

        .slide-container::after {
            content: "";
            position: absolute; bottom: 0; left: 0;
            width: 100%; height: 8px;
            background: linear-gradient(90deg, #1a365d 0%, #00bcd4 100%);
            z-index: 2;
        }

        /* TYPOGRAPHY */
        h1, h2, h3, h4 { font-family: 'Montserrat', sans-serif; color: #1a365d; }
        .slide-title { font-size: 40px; font-weight: 700; margin: 55px 0 0 60px; position: relative; z-index: 1; display: flex; align-items: center; gap: 15px; }
        .slide-title span { color: #00bcd4; }
        .slide-subtitle { font-size: 18px; color: #64748b; margin: 10px 0 0 60px; font-weight: 500; position: relative; z-index: 1; }
        .content-area { flex-grow: 1; padding: 30px 60px 50px 60px; display: flex; align-items: center; position: relative; z-index: 1; }

        /* Slide 1: Title Slide */
        .title-slide { text-align: left; justify-content: center; background-color: #f8fafc; }
        .title-slide h1 { font-size: 72px; line-height: 1.1; margin-bottom: 20px; border-left: 10px solid #00bcd4; padding-left: 30px; }
        .title-slide .subtitle { font-size: 28px; color: #475569; max-width: 800px; margin-bottom: 40px; padding-left: 40px; }
        .title-slide .benefit-box { background: #1a365d; color: white; padding: 25px 40px; border-radius: 0 50px 50px 0; display: inline-block; font-size: 20px; font-weight: 500; }

        /* Slide 2: Styled Bullet Points */
        .bullet-list { width: 100%; }
        .bullet-list ul { list-style: none; }
        .bullet-list li { display: flex; align-items: flex-start; gap: 20px; margin-bottom: 30px; background: #f8fafc; padding: 25px; border-radius: 15px; border-left: 5px solid #00bcd4; }
        .bullet-list i { color: #00bcd4; font-size: 32px; margin-top: 5px; }
        .bullet-list h3 { font-size: 24px; margin-bottom: 5px; color: #1a365d; }
        .bullet-list p { font-size: 18px; color: #64748b; }

        /* Slide 3: Detalles del Curso (Grid & Cards) */
        .grid-details { display: grid; grid-template-columns: 1.2fr 1fr; gap: 40px; width: 100%; }
        .detail-card { background: #f8fafc; padding: 30px; border-radius: 20px; border: 1px solid #e2e8f0; }
        .detail-item { display: flex; align-items: center; gap: 20px; margin-bottom: 25px; }
        .detail-item:last-child { margin-bottom: 0; }
        .detail-icon { width: 60px; height: 60px; background: rgba(0, 188, 212, 0.1); border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 24px; color: #00bcd4; }
        .detail-text h4 { font-size: 16px; color: #64748b; font-weight: 500; text-transform: uppercase; letter-spacing: 1px; }
        .detail-text p { font-size: 22px; font-weight: 700; color: #1a365d; }
        
        /* Caja de Urgencia e Inversión */
        .pricing-card { background: #1a365d; color: white; padding: 35px; border-radius: 20px; display: flex; flex-direction: column; justify-content: space-between; position: relative; overflow: hidden; }
        .pricing-card::before { content: ""; position: absolute; bottom: -50px; right: -50px; width: 150px; height: 150px; background: rgba(0,188,212,0.15); border-radius: 50%; }
        .price-tag { margin: 20px 0; }
        .price-regular { text-decoration: line-through; color: #94a3b8; font-size: 18px; }
        .price-promo { font-size: 48px; font-weight: 800; color: #00bcd4; font-family: 'Montserrat', sans-serif; }
        .urgency-badge { background: rgba(239, 68, 68, 0.2); border: 1px solid #ef4444; color: #fca5a5; padding: 12px 20px; border-radius: 10px; font-size: 16px; font-weight: 600; display: flex; align-items: center; gap: 10px; }

        /* Slide 4: Aval y Certificación */
        .grid-cert { display: grid; grid-template-columns: 1fr 1.1fr; gap: 50px; width: 100%; }
        .cert-info { display: flex; flex-direction: column; justify-content: center; gap: 25px; }
        .cert-badge { display: flex; align-items: center; gap: 15px; background: #f0fdfa; border: 1.5px solid #14b8a6; padding: 20px; border-radius: 15px; }
        .cert-badge i { font-size: 32px; color: #14b8a6; }
        .cert-badge h4 { font-size: 18px; color: #115e59; }
        .cert-list { space-y: 20px; }
        .cert-list-item { display: flex; align-items: flex-start; gap: 15px; font-size: 18px; color: #475569; margin-bottom: 15px; }
        .cert-list-item i { color: #00bcd4; font-size: 20px; margin-top: 4px; }
        .cert-mockup { background: #f8fafc; border: 2px dashed #cbd5e1; border-radius: 20px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px; text-align: center; position: relative; }
        .cert-mockup-icon { font-size: 80px; color: #1a365d; margin-bottom: 20px; opacity: 0.85; }

        /* Slide 5: ¿Para quién es este curso? */
        .grid-profiles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; width: 100%; }
        .profile-card { background: #f8fafc; border: 1px solid #e2e8f0; border-top: 6px solid #1a365d; border-radius: 20px; padding: 45px 30px; text-align: center; transition: all 0.3s ease; }
        .profile-card:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(26, 54, 93, 0.08); }
        .profile-card.highlight { border-top-color: #00bcd4; background: #ffffff; }
        .profile-icon { width: 80px; height: 80px; background: rgba(26, 54, 93, 0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 32px; color: #1a365d; margin: 0 auto 25px auto; transition: all 0.3s ease; }
        .profile-card.highlight .profile-icon { background: rgba(0, 188, 212, 0.1); color: #00bcd4; }
        .profile-card h3 { font-size: 24px; margin-bottom: 15px; }
        .profile-card p { font-size: 16px; color: #64748b; line-height: 1.6; }

        /* Slide 6: Metodología en 5 pasos */
        .grid-method { display: grid; grid-template-columns: repeat(5, 1fr); gap: 15px; width: 100%; }
        .method-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 18px; padding: 30px 20px; display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; transition: all 0.3s ease; }
        .method-card:hover { background: #ffffff; border-color: #00bcd4; transform: translateY(-5px); box-shadow: 0 10px 20px rgba(26, 54, 93, 0.05); }
        .method-number { position: absolute; top: -18px; left: 20px; width: 36px; height: 36px; background: #00bcd4; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 16px; box-shadow: 0 4px 10px rgba(0, 188, 212, 0.3); }
        .method-icon { font-size: 34px; color: #1a365d; margin: 15px 0; }
        .method-card h4 { font-size: 15px; font-weight: 700; margin-bottom: 10px; color: #1a365d; line-height: 1.3; }
        .method-card p { font-size: 12px; color: #64748b; line-height: 1.5; }

        /* Slides 7 y 8: Temarios */
        .syllabus-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; width: 100%; }
        .module-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 20px; padding: 30px; display: flex; flex-direction: column; transition: all 0.3s ease; }
        .module-card:hover { border-color: #00bcd4; transform: translateY(-5px); box-shadow: 0 10px 20px rgba(26, 54, 93, 0.05); }
        .module-header { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; }
        .module-number { background: #1a365d; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 18px; shrink-0: 0; }
        .module-card h3 { font-size: 18px; line-height: 1.3; font-weight: 700; }
        .module-content { list-style: none; }
        .module-content li { font-size: 14px; color: #475569; margin-bottom: 12px; display: flex; gap: 10px; line-height: 1.4; }
        .module-content li i { color: #00bcd4; font-size: 12px; margin-top: 4px; }

        .syllabus-grid-4 { grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(2, 1fr); gap: 20px; }
        .syllabus-grid-4 .module-card { padding: 20px 30px; }

        /* Slide 9: Bonos Incluidos */
        .bonuses-grid { display: grid; grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(2, 1fr); gap: 20px; width: 100%; }
        .bonus-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 15px; padding: 25px; display: flex; gap: 20px; align-items: flex-start; transition: all 0.3s ease; position: relative; }
        .bonus-card:hover { background: white; border-color: #00bcd4; transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0, 188, 212, 0.05); }
        .bonus-icon { width: 55px; height: 55px; background: rgba(0, 188, 212, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 22px; color: #00bcd4; shrink-0: 0; }
        .bonus-details h4 { font-size: 16px; font-weight: 700; margin-bottom: 5px; color: #1a365d; }
        .bonus-details p { font-size: 13px; color: #64748b; line-height: 1.4; }
        .bonus-badge { position: absolute; top: 15px; right: 15px; background: #f0fdfa; border: 1px solid #86efac; color: #166534; font-size: 9px; font-weight: 700; padding: 3px 8px; border-radius: 10px; text-transform: uppercase; }

        /* Slide 10: Planes de Inversión */
        .plans-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; width: 100%; align-items: stretch; }
        .plan-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 20px; padding: 35px 30px; display: flex; flex-direction: column; justify-content: space-between; position: relative; transition: all 0.3s ease; }
        .plan-card:hover { transform: translateY(-5px); }
        .plan-card.highlight { background: white; border: 2.5px solid #00bcd4; box-shadow: 0 15px 35px rgba(0, 188, 212, 0.12); }
        .plan-card.highlight::before {
            content: "RECOMENDADO ⭐";
            position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
            background: #00bcd4; color: white; font-size: 11px; font-weight: 800;
            padding: 4px 16px; border-radius: 20px; letter-spacing: 0.5px; box-shadow: 0 4px 10px rgba(0, 188, 212, 0.3);
        }
        .plan-header h3 { font-size: 20px; font-weight: 800; margin-bottom: 5px; text-transform: uppercase; }
        .plan-card.highlight .plan-header h3 { color: #00bcd4; }
        .plan-price { margin: 20px 0; border-bottom: 1px solid #e2e8f0; padding-bottom: 15px; }
        .plan-price .amount { font-size: 38px; font-weight: 800; color: #1a365d; font-family: 'Montserrat', sans-serif; }
        .plan-price .currency { font-size: 16px; color: #64748b; font-weight: 500; }
        .plan-features { list-style: none; font-size: 13px; color: #475569; space-y: 10px; flex-grow: 1; }
        .plan-features li { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .plan-features li i { color: #00bcd4; font-size: 14px; }
        .plan-features li.disabled { color: #94a3b8; text-decoration: line-through; }
        .plan-features li.disabled i { color: #cbd5e1; }

        /* Slide 11: Garantía y FAQ (NUEVA) */
        .grid-faq { display: grid; grid-template-columns: 1fr 1.3fr; gap: 40px; width: 100%; }
        .guarantee-box { background: linear-gradient(135deg, #1a365d 0%, #0f2038 100%); color: white; padding: 40px 35px; border-radius: 20px; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; border: 1px solid rgba(255,255,255,0.1); position: relative; }
        .guarantee-box i { font-size: 56px; color: #00bcd4; margin-bottom: 20px; filter: drop-shadow(0 0 15px rgba(0,188,212,0.4)); }
        .guarantee-box h3 { color: white; font-size: 26px; margin-bottom: 15px; font-weight: 800; }
        .guarantee-box p { font-size: 15px; color: #cbd5e1; line-height: 1.6; }
        
        .faq-list { display: flex; flex-direction: column; gap: 20px; }
        .faq-item { background: #f8fafc; border: 1px solid #e2e8f0; border-left: 5px solid #1a365d; padding: 20px; border-radius: 12px; }
        .faq-item.active { border-left-color: #00bcd4; background: white; }
        .faq-item h4 { font-size: 16px; font-weight: 700; margin-bottom: 8px; color: #1a365d; display: flex; align-items: center; gap: 10px; }
        .faq-item h4 i { color: #00bcd4; font-size: 16px; }
        .faq-item p { font-size: 14px; color: #64748b; line-height: 1.5; padding-left: 26px; }

        /* Slide 12: Cierre y CTA (NUEVA) */
        .cta-container { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; text-align: center; }
        .cta-box { background: white; border: 2.5px solid #1a365d; border-radius: 24px; padding: 45px 60px; max-width: 900px; width: 100%; box-shadow: 0 15px 40px rgba(26, 54, 93, 0.08); position: relative; }
        .cta-box::after { content: ""; position: absolute; inset: -2.5px; border-radius: 24px; border: 2.5px solid transparent; background: linear-gradient(90deg, #1a365d, #00bcd4) border-box; -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0); -webkit-mask-composite: destination-out; mask-composite: exclude; pointer-events: none; }
        
        .cta-btn { background: #1a365d; color: white; font-family: 'Montserrat', sans-serif; font-size: 24px; font-weight: 800; padding: 22px 50px; border-radius: 50px; text-transform: uppercase; letter-spacing: 0.5px; display: inline-flex; align-items: center; gap: 15px; transition: all 0.3s ease; border: none; cursor: pointer; margin-bottom: 25px; box-shadow: 0 10px 25px rgba(26,54,93,0.25); }
        .cta-btn:hover { background: #00bcd4; transform: scale(1.03); box-shadow: 0 10px 25px rgba(0,188,212,0.35); }
        
        .contact-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; width: 100%; max-width: 850px; margin-top: 35px; border-t: 1px solid #e2e8f0; padding-top: 30px; }
        .contact-item { display: flex; align-items: center; justify-content: center; gap: 12px; font-size: 16px; color: #475569; font-weight: 500; }
        .contact-item i { font-size: 22px; color: #00bcd4; }

        /* Imágenes de apoyo */
        .bg-image-overlay {
            position: absolute; right: 0; top: 0; width: 45%; height: 100%;
            background-size: cover; background-position: center;
            clip-path: polygon(20% 0%, 100% 0%, 100% 100%, 0% 100%);
        }
        .slide-number { position: absolute; bottom: 25px; right: 60px; font-size: 14px; font-weight: 600; color: #94a3b8; z-index: 5; }
    </style>
</head>
